# ============================================
# .env.example — COPY THIS TO .env FOR LOCAL TESTING
# DO NOT put real keys here. Real keys go in .env (gitignored)
# In production, these live in GitHub Secrets.
# ============================================

# NVIDIA NIM API (free tier) — get from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (your paid 3rd-party key)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # Adam voice

# YouTube Data API v3 — from Google Cloud Console
YOUTUBE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx

# Copyright-free stock video sources (FREE)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Unsplash photos — high-quality royalty-free images
# Get from https://unsplash.com/developers (Access Key only)
UNSPLASH_ACCESS_KEY=

# Note: web-wide image search is provided automatically via DuckDuckGo
# (no key required). Google Custom Search was removed because Google
# deprecated the "search the entire web" toggle.

# Instagram (optional — needed only if scraping login-gated content)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Contact email used in removal disclaimer
OWNER_CONTACT_EMAIL=youremail@example.com

# Optional: Telegram notifications for pipeline status
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
